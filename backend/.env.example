# ══════════════════════════════════════════
#  NexaBank Environment Configuration
#  Copy this to .env and fill in your values
# ══════════════════════════════════════════

# Server
NODE_ENV=development
PORT=5000
API_VERSION=v1

# MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/nexabank

# JWT Secrets
JWT_SECRET=nexabanksecret
JWT_REFRESH_SECRET=nexabank_refresh_secret_key_change_in_production
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Email (Nodemailer / Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=yourmail@gmail.com
EMAIL_PASS=yourpassword
EMAIL_FROM=NexaBank <noreply@nexabank.com>

# AWS (for production hosting)
AWS_REGION=ap-south-1
AWS_S3_BUCKET=nexabank-assets
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# OTP
OTP_EXPIRE_MINUTES=10

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://nexabank.example.com

# Logging
LOG_LEVEL=info
